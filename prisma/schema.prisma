generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id           Int      @id @default(autoincrement())
  nome         String
  descricao    String?
  quantidade   Int
  preco        Float
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}