      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:3000/produtos", "host": ["localhost"], "port": "3000", "path": ["produtos"] }
      }
    },
    {
      "name": "RF02 — Buscar Produto por ID",
      "request": {
