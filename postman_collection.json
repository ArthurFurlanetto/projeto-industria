        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Parafuso M8 Atualizado\",\n  \"descricao\": \"Parafuso sextavado M8x30mm — aço inox\",\n  \"quantidade\": 350,\n  \"preco\": 1.20\n}"
        }
